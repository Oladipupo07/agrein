# Agrein Client Environment Configuration
# Copy this file to `.env` in the client directory and fill in real values.
# Note: Vite only exposes environment variables prefixed with `VITE_` to browser code.

# ==========================================
# 1. API CONNECTION
# ==========================================
# Base URL of your deployed Express API server.
# Development default: http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# ==========================================
# 2. INTERSWITCH WEBPAY INLINE GATEWAY
# ==========================================
# Obtain credentials from Quickteller Business Portal (https://quicktellerbusiness.com/)
VITE_INTERSWITCH_MERCHANT_CODE=MX179463
VITE_INTERSWITCH_PAY_ITEM_ID=9646887
VITE_INTERSWITCH_ENV=sandbox # Options: sandbox | production

# ==========================================
# 3. SUPABASE CLIENT CONFIG (OPTIONAL)
# ==========================================
# Supabase Anon Public Key & URL for client-side direct calls (if enabled)
