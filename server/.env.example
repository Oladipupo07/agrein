# Agrein Server Environment Configuration
# Copy this file to `.env` in the server directory and fill in real values.
# `.env` is gitignored; never commit secrets to version control.

# ==========================================
# 1. REQUIRED SERVER SECURITY
# ==========================================
# Secret key used to sign and verify JWT tokens.
# Generate a secure random 64-byte key using:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=agrein_super_secret_jwt_key_production_2026_change_me

# Port for the Express API server (default: 5000)
PORT=5000

# ==========================================
# 2. SUPABASE / POSTGRESQL DATABASE
# ==========================================
# PostgreSQL connection string from Supabase or direct Postgres host.
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# If left empty, the server automatically falls back to an in-memory database with pre-seeded demo data.
DATABASE_URL=

# Supabase Project Credentials (optional if using direct DATABASE_URL)
SUPABASE_URL=https://svgwkmnpjkyjjboultfn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN2Z3drbW5wamt5ampib3VsdGZuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4NDU0MzQ0NywiZXhwIjoyMTAwMTE5NDQ3fQ.hLUaLrc-90vlxL2n8NqeaUpVLOH2ZGi9_koFJqAnDbI

# ==========================================
# 3. INTERSWITCH WEBPAY GATEWAY
# ==========================================
# Obtain credentials from Quickteller Business Portal (https://quicktellerbusiness.com/)
# Test / Sandbox Merchant Code: MX2609 or your assigned Merchant Code
INTERSWITCH_MERCHANT_CODE=MX179463
INTERSWITCH_PAY_ITEM_ID=9646887
INTERSWITCH_SECRET_KEY=vAN-6lgB3CajeE8
INTERSWITCH_CLIENT_ID=IKIAD18C4FB0E13E597A358EE3BCF8F59592316165F7
INTERSWITCH_ENV=sandbox # Options: sandbox | production

# ==========================================
# 4. CORS & FRONTEND ORIGIN
# ==========================================
# Comma-separated origins allowed to connect to the Express API.
# Local dev default: http://localhost:5173 or http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
