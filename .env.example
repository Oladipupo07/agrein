# Agrein — environment configuration
#
# Copy this file to `.env` at the same path, then fill in real values.
# Never commit a real `.env`; it is gitignored.
#
# To generate a strong JWT secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# ---------- Server (server/.env reads these) ----------
# Server runs the API on port 5000 by default.
PORT=5000

# REQUIRED: secret used to sign and verify JWTs. No default — server will
# refuse to start without this set.
JWT_SECRET=

# OPTIONAL: PostgreSQL connection string.
# If unset, the server falls back to an in-memory mock DB pre-seeded with the
# demo accounts described in README.md.
# DATABASE_URL=postgres://user:password@host:5432/agrein

# Comma-separated list of origins allowed to call the API.
# Defaults to http://localhost:3000 for local dev.
# In production, set this to your deployed frontend origin(s).
# CORS_ORIGIN=http://localhost:3000
